{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "prHourlyLimit": 0,
  "labels": ["dependencies"],
  "rebaseWhen": "behind-base-branch",
  "separateMinorPatch": true,
  "minimumReleaseAge": "24 hours",
  "flux": { "managerFilePatterns": ["/components/.+\\.yaml$/"] },
  "github-actions": { "enabled": false },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/components/coder/controllers/base/ocirepository\\.yaml$/"],
      "matchStrings": [
        "url:\\s+oci://ghcr\\.io/coder/chart/coder[\\s\\S]*?tag:\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "coder/coder",
      "packageNameTemplate": "coder/coder",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "description": "Use semver-coerced versioning for all sources",
      "matchDatasources": ["docker", "helm", "git-refs", "github-tags"],
      "versioning": "semver-coerced",
      "pinDigests": true
    },
    {
      "description": "Automerge patch+minor for >=1.x",
      "matchDatasources": ["docker", "helm", "git-refs", "github-tags"],
      "matchCurrentVersion": "/^v?[1-9]/",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Ignore v-prefixed legacy tags in agentgateway chart registry",
      "matchPackagePatterns": ["cr\\.agentgateway\\.dev/charts/"],
      "allowedVersions": "/^[0-9]/"
    },
    {
      "description": "Automerge patch only for 0.x",
      "matchDatasources": ["docker", "helm", "git-refs", "github-tags"],
      "matchCurrentVersion": "/^v?0\\./",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true
    },
    {
      "description": "Coder: stable-only. customManager above tracks coder/coder via github-releases so respectLatest honors GitHub's 'latest' marker (stable); disable the flux lookup to avoid duplicate mainline PRs.",
      "matchManagers": ["flux"],
      "matchPackageNames": ["ghcr.io/coder/chart/coder"],
      "enabled": false
    }
  ]
}
