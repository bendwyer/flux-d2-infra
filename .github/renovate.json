{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "prHourlyLimit": 0,
  "labels": ["dependencies"],
  "rebaseWhen": "behind-base-branch",
  "separateMinorPatch": true,
  "flux": { "managerFilePatterns": ["/components/.+\\.yaml$/"] },
  "github-actions": { "enabled": false },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/components/hcp-terraform-operator/configs/home/agentpool\\.yaml$/"],
      "matchStrings": [
        "image:\\s+\"hashicorp/tfc-agent:(?<currentValue>[^\"@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?\""
      ],
      "depNameTemplate": "hashicorp/tfc-agent",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Use semver-coerced versioning for all sources",
      "matchDatasources": ["docker", "helm", "git-refs", "github-tags"],
      "versioning": "semver-coerced",
      "pinDigests": true
    },
    {
      "description": "Automerge patch+minor for >=1.x",
      "matchDatasources": ["docker", "helm", "git-refs", "github-tags"],
      "matchCurrentVersion": "/^v?[1-9]/",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Ignore v-prefixed legacy tags in agentgateway chart registry",
      "matchPackagePatterns": ["cr\\.agentgateway\\.dev/charts/"],
      "allowedVersions": "/^[0-9]/"
    },
    {
      "description": "Automerge patch only for 0.x",
      "matchDatasources": ["docker", "helm", "git-refs", "github-tags"],
      "matchCurrentVersion": "/^v?0\\./",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true
    },
    {
      "description": "Coder: track the published chart tags in GHCR directly (only real chart tags, so phantom versions like 2.33.6 can't be proposed). Automerge current-line patches immediately for prompt security/bugfix.",
      "matchManagers": ["flux"],
      "matchPackageNames": ["ghcr.io/coder/chart/coder"],
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "pinDigests": false
    },
    {
      "description": "Coder: soak new minor/major releases ~35d so we adopt a minor only once it is promoted to stable (stable = N-1, monthly cadence): https://coder.com/docs/install/releases",
      "matchManagers": ["flux"],
      "matchPackageNames": ["ghcr.io/coder/chart/coder"],
      "matchUpdateTypes": ["minor", "major"],
      "minimumReleaseAge": "35 days",
      "internalChecksFilter": "strict",
      "automerge": false
    }
  ]
}
